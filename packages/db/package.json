{
  "name": "@water-delivery/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "db:generate": "bash -c 'source scripts/resolve-db-url.sh && ../../node_modules/.bin/drizzle-kit generate'",
    "db:migrate": "bash -c 'source scripts/resolve-db-url.sh && ../../node_modules/.bin/drizzle-kit migrate'",
    "db:push": "bash -c 'source scripts/resolve-db-url.sh && ../../node_modules/.bin/drizzle-kit push'",
    "db:studio": "bash scripts/studio.sh",
    "db:seed": "bash -c 'source scripts/resolve-db-url.sh && ../../node_modules/.bin/tsx src/seed.ts'",
    "db:reseed": "bash -c 'source scripts/resolve-db-url.sh && ../../node_modules/.bin/tsx src/seed.ts --fresh'",
    "build": "tsc",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.0"
  }
}
