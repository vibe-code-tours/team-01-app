# Database
# Devcontainer / compose services: postgres:5432 | Host Mac terminal: localhost:5433
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/water_delivery
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=water_delivery

# Redis
REDIS_URL=redis://redis:6379

# better-auth
BETTER_AUTH_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
BETTER_AUTH_URL=https://api-bir004ynp-klockdevops.vercel.app

# API
API_PORT=3001
API_CORS_ORIGIN=https://water-delivery-system-prod.vercel.app

# Web
NEXT_PUBLIC_API_URL=https://api-bir004ynp-klockdevops.vercel.app

# Docker
NODE_ENV=development

# Vibe Code Tours proxy (Claude Code CLI)
# Get VIBE_PROXY and VIBE_KEY from your cohort channel
VIBE_PROXY=
VIBE_KEY=
# Optional model overrides (defaults: mimo-v2.5-pro / mimo-v2.5)
# ANTHROPIC_MODEL=mimo-v2.5-pro
# ANTHROPIC_SMALL_FAST_MODEL=mimo-v2.5