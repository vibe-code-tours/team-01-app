# Database
# DB scripts auto-pick the reachable host: postgres:5432, host.docker.internal:5433, or localhost:5433
# Set DATABASE_FORCE_URL=1 to always use DATABASE_URL as written below
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/water_delivery
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=water_delivery

# Redis
REDIS_URL=redis://redis:6379

# better-auth
BETTER_AUTH_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3001

# API
API_PORT=3001
API_CORS_ORIGIN=http://localhost:3000

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001

# Docker
NODE_ENV=development

# Vibe Code Tours proxy (Claude Code CLI)
# Get VIBE_PROXY and VIBE_KEY from your cohort channel
VIBE_PROXY=
VIBE_KEY=
# Optional model overrides (defaults: mimo-v2.5-pro / mimo-v2.5)
# ANTHROPIC_MODEL=mimo-v2.5-pro
# ANTHROPIC_SMALL_FAST_MODEL=mimo-v2.5